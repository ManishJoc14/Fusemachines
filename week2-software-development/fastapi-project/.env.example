# App Configuration
PROJECT_NAME=YourProjectName
VERSION=1.0.0
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# Security
SECRET_KEY=your-secret-key-here => you can generate using this command: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))" 
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]